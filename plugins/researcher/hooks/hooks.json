{
  "version": "1.0.0",
  "description": "Researcher plugin - checks environment setup on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/check-setup.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
